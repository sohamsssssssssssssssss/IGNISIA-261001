APP_ENV=development
ENVIRONMENT=development
DEBUG=false
DEMO_MODE=true
MOCK_MODE=true
REQUIRE_AUTH=false
API_TOKENS=viewer:demo-viewer-token,analyst:demo-analyst-token,admin:demo-admin-token
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///backend/data/intellicredit.db
DATABASE_PATH=backend/data/intellicredit.db
MODEL_ARTIFACT_DIR=backend/artifacts
ENABLE_RAG=true
ENABLE_LOCAL_GENERATION=true
ENABLE_WEB_INTEL=true
TAVILY_API_KEY=
SCORE_HISTORY_SEED_COUNT=5
SEED_SCORE_HISTORY=false
DEFAULT_HISTORY_PAGE_SIZE=20
MAX_HISTORY_PAGE_SIZE=100
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TOKEN=demo-analyst-token
